// ============================================================================
// SYNTHESIS PRIMITIVES
// ============================================================================
function makeNoiseBuffer(ctx, dur) {
  const buf = ctx.createBuffer(1, Math.max(1, Math.floor(ctx.sampleRate * dur)), ctx.sampleRate);
  const d = buf.getChannelData(0);
  for (let i = 0; i < d.length; i++) d[i] = Math.random() * 2 - 1;
  return buf;
}
function makeDriveShaper(ctx, drive) {
  const shaper = ctx.createWaveShaper();
  const k = drive * 80;
  const N = 1024;
  const curve = new Float32Array(N);
  for (let i = 0; i < N; i++) {
    const x = (i / (N - 1)) * 2 - 1;
    curve[i] = Math.tanh(x * (1 + k)) / Math.tanh(1 + k);
  }
  shaper.curve = curve;
  shaper.oversample = "4x";
  return shaper;
}

// ============================================================================
// PER-DRUM SYNTHESIS
// ============================================================================
function synthKick(ctx, t, p, vel, dest) {
  const osc = ctx.createOscillator();
  osc.type = "sine";
  const oscGain = ctx.createGain();
  const pDec = p.pitchDecay / 1000;
  osc.frequency.setValueAtTime(p.pitchStart, t);
  const steps = 16;
  for (let i = 1; i <= steps; i++) {
    const frac = i / steps;
    const shaped = Math.pow(frac, p.pitchCurve / 2);
    const f = p.pitchStart - (p.pitchStart - p.pitchEnd) * shaped;
    osc.frequency.setValueAtTime(Math.max(f, 1), t + frac * pDec);
  }
  const decSec = p.ampDecay / 1000;
  oscGain.gain.setValueAtTime(0, t);
  oscGain.gain.linearRampToValueAtTime(vel, t + 0.0008);
  oscGain.gain.exponentialRampToValueAtTime(0.0001, t + decSec);
  osc.connect(oscGain);

  // Click
  const clickDur = 0.04;
  const clickSrc = ctx.createBufferSource();
  clickSrc.buffer = (() => {
    const b = ctx.createBuffer(1, Math.floor(ctx.sampleRate * clickDur), ctx.sampleRate);
    const d = b.getChannelData(0);
    for (let i = 0; i < d.length; i++) {
      d[i] = (Math.random() * 2 - 1) * Math.exp(-i / (ctx.sampleRate * 0.004));
    }
    return b;
  })();
  const cf = ctx.createBiquadFilter();
  cf.type = "highpass"; cf.frequency.value = p.clickTone; cf.Q.value = 0.7;
  const cg = ctx.createGain();
  cg.gain.value = p.click * vel * 0.7;
  clickSrc.connect(cf).connect(cg);

  // Sub
  const sub = ctx.createOscillator();
  sub.type = "sine"; sub.frequency.value = p.pitchEnd * 0.65;
  const sg = ctx.createGain();
  sg.gain.setValueAtTime(0, t);
  sg.gain.linearRampToValueAtTime(p.sub * 0.6 * vel, t + 0.005);
  sg.gain.exponentialRampToValueAtTime(0.0001, t + decSec * 1.4);
  sub.connect(sg);

  const mix = ctx.createGain();
  mix.gain.value = 0.85;
  oscGain.connect(mix); cg.connect(mix); sg.connect(mix);

  if (p.drive > 0) {
    const sh = makeDriveShaper(ctx, p.drive);
    const post = ctx.createGain();
    post.gain.value = 1 / (1 + p.drive * 0.6);
    mix.connect(sh).connect(post).connect(dest);
  } else mix.connect(dest);

  const stopAt = t + Math.max(decSec * 1.6, 0.5);
  osc.start(t); osc.stop(stopAt);
  sub.start(t); sub.stop(stopAt);
  clickSrc.start(t); clickSrc.stop(t + clickDur);
}

function synthSnare(ctx, t, p, vel, dest) {
  // Two sine tones (shell)
  const tonesGain = ctx.createGain();
  const toneDec = p.toneDecay / 1000;
  tonesGain.gain.setValueAtTime(0, t);
  tonesGain.gain.linearRampToValueAtTime(p.toneAmount * vel, t + 0.001);
  tonesGain.gain.exponentialRampToValueAtTime(0.0001, t + toneDec);
  [p.tone1, p.tone2].forEach(freq => {
    const o = ctx.createOscillator();
    o.type = "sine"; o.frequency.value = freq;
    o.connect(tonesGain);
    o.start(t); o.stop(t + toneDec + 0.05);
  });

  // Noise (snares wires)
  const dur = (p.noiseDecay / 1000) + 0.05;
  const ns = ctx.createBufferSource();
  ns.buffer = makeNoiseBuffer(ctx, dur);
  const hp = ctx.createBiquadFilter();
  hp.type = "highpass"; hp.frequency.value = p.noiseTone; hp.Q.value = 0.7;
  const ng = ctx.createGain();
  ng.gain.setValueAtTime(0, t);
  ng.gain.linearRampToValueAtTime(p.noiseAmount * vel, t + 0.001);
  ng.gain.exponentialRampToValueAtTime(0.0001, t + p.noiseDecay / 1000);
  ns.connect(hp).connect(ng);

  const mix = ctx.createGain();
  mix.gain.value = 0.7;
  tonesGain.connect(mix); ng.connect(mix);
  if (p.drive > 0) {
    const sh = makeDriveShaper(ctx, p.drive);
    mix.connect(sh).connect(dest);
  } else mix.connect(dest);
  ns.start(t); ns.stop(t + dur);
}

function synthHat(ctx, t, p, vel, dest) {
  // Filtered noise with metallic harmonics via square stack
  const dur = (p.decay / 1000) + 0.05;
  const ns = ctx.createBufferSource();
  ns.buffer = makeNoiseBuffer(ctx, dur);
  const bp = ctx.createBiquadFilter();
  bp.type = "bandpass"; bp.frequency.value = p.tone; bp.Q.value = p.q;
  const hp = ctx.createBiquadFilter();
  hp.type = "highpass"; hp.frequency.value = p.tone * 0.65;
  const g = ctx.createGain();
  g.gain.setValueAtTime(0, t);
  g.gain.linearRampToValueAtTime(vel * 0.55, t + 0.0008);
  g.gain.exponentialRampToValueAtTime(0.0001, t + p.decay / 1000);
  ns.connect(bp).connect(hp).connect(g).connect(dest);
  ns.start(t); ns.stop(t + dur);
}

function synthTom(ctx, t, p, vel, dest) {
  const osc = ctx.createOscillator();
  osc.type = "sine";
  const og = ctx.createGain();
  const pDec = p.pitchDecay / 1000;
  osc.frequency.setValueAtTime(p.pitch, t);
  osc.frequency.exponentialRampToValueAtTime(Math.max(p.pitchEnd, 1), t + pDec);
  const dec = p.ampDecay / 1000;
  og.gain.setValueAtTime(0, t);
  og.gain.linearRampToValueAtTime(vel, t + 0.001);
  og.gain.exponentialRampToValueAtTime(0.0001, t + dec);
  osc.connect(og);
  const mix = ctx.createGain();
  mix.gain.value = 0.85;
  og.connect(mix);

  if (p.click > 0) {
    const cd = 0.02;
    const cs = ctx.createBufferSource();
    cs.buffer = makeNoiseBuffer(ctx, cd);
    const cf = ctx.createBiquadFilter();
    cf.type = "highpass"; cf.frequency.value = 3000;
    const cg = ctx.createGain();
    cg.gain.value = p.click * vel * 0.45;
    cs.connect(cf).connect(cg).connect(mix);
    cs.start(t); cs.stop(t + cd);
  }

  if (p.drive > 0) {
    const sh = makeDriveShaper(ctx, p.drive);
    mix.connect(sh).connect(dest);
  } else mix.connect(dest);
  osc.start(t); osc.stop(t + dec + 0.1);
}

function synthClap(ctx, t, p, vel, dest) {
  // Three quick noise bursts + tail
  const offsets = [0, p.spread / 1000, (p.spread * 2) / 1000];
  offsets.forEach(off => {
    const dur = 0.03;
    const ns = ctx.createBufferSource();
    ns.buffer = makeNoiseBuffer(ctx, dur);
    const bp = ctx.createBiquadFilter();
    bp.type = "bandpass"; bp.frequency.value = p.tone; bp.Q.value = p.q;
    const g = ctx.createGain();
    const start = t + off;
    g.gain.setValueAtTime(0, start);
    g.gain.linearRampToValueAtTime(vel * 0.55, start + 0.001);
    g.gain.exponentialRampToValueAtTime(0.001, start + 0.012);
    ns.connect(bp).connect(g).connect(dest);
    ns.start(start); ns.stop(start + dur);
  });
  // Tail
  const ts = t + (p.spread * 3) / 1000;
  const td = (p.decay / 1000) + 0.05;
  const tns = ctx.createBufferSource();
  tns.buffer = makeNoiseBuffer(ctx, td);
  const tbp = ctx.createBiquadFilter();
  tbp.type = "bandpass"; tbp.frequency.value = p.tone; tbp.Q.value = p.q * 1.3;
  const tg = ctx.createGain();
  tg.gain.setValueAtTime(0, ts);
  tg.gain.linearRampToValueAtTime(vel * 0.4, ts + 0.002);
  tg.gain.exponentialRampToValueAtTime(0.0001, ts + p.decay / 1000);
  tns.connect(tbp).connect(tg).connect(dest);
  tns.start(ts); tns.stop(ts + td);
}

function synthPerc(ctx, t, p, vel, dest) {
  // Cowbell-style: two square oscs through bandpass with sharp envelope
  const dec = p.decay / 1000;
  const oscMix = ctx.createGain();
  oscMix.gain.value = 0.32;
  [p.pitch1, p.pitch2].forEach(freq => {
    const o = ctx.createOscillator();
    o.type = "square"; o.frequency.value = freq;
    o.connect(oscMix);
    o.start(t); o.stop(t + dec + 0.05);
  });
  const bp = ctx.createBiquadFilter();
  bp.type = "bandpass"; bp.frequency.value = p.tone; bp.Q.value = 4;
  const env = ctx.createGain();
  env.gain.setValueAtTime(0, t);
  env.gain.linearRampToValueAtTime(vel * 0.55, t + 0.002);
  env.gain.exponentialRampToValueAtTime(0.0001, t + dec);
  oscMix.connect(bp).connect(env);
  if (p.drive > 0) {
    const sh = makeDriveShaper(ctx, p.drive);
    env.connect(sh).connect(dest);
  } else env.connect(dest);
}

