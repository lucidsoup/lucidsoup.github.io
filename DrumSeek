// ============================================================================
// MAIN COMPONENT
// ============================================================================
export default function DrumSeek() {
  // ---- Drum kit state ----
  const [drums, setDrums] = useState(() => {
    const initial = {};
    DRUM_NAMES.forEach(name => initial[name] = { ...KITS[DEFAULT_KIT][name] });
    return initial;
  });
  const [selectedDrum, setSelectedDrum] = useState("KICK");

  const setDrumParam = (drumName, key, value) => {
    setDrums(d => ({ ...d, [drumName]: { ...d[drumName], [key]: value } }));
  };

  // ---- Sequencer state ----
  const [tracks, setTracks] = useState(() => {
    const t = {};
    DRUM_NAMES.forEach(name => t[name] = [...KITS[DEFAULT_KIT].pattern[name]]);
    return t;
  });
  const [bpm, setBpm] = useState(KITS[DEFAULT_KIT].bpm);
  const [swing, setSwing] = useState(0);    // 0-50%
  const [humanize, setHumanize] = useState(0); // 0-15%
  const [masterVol, setMasterVol] = useState(0.85);
  const [playing, setPlaying] = useState(false);
  const [currentStep, setCurrentStep] = useState(-1);
  const stepIdxRef = useRef(0);

  // ---- Audio infrastructure ----
  const audioCtxRef = useRef(null);
  const masterGainRef = useRef(null);
  const analyserRef = useRef(null);
  const [audioReady, setAudioReady] = useState(false);

  const initAudio = useCallback(() => {
    if (audioCtxRef.current) return;
    const Ctx = window.AudioContext || window.webkitAudioContext;
    const ctx = new Ctx();
    const master = ctx.createGain();
    master.gain.value = masterVol;
    const comp = ctx.createDynamicsCompressor();
    comp.threshold.value = -8;
    comp.ratio.value = 4;
    comp.attack.value = 0.001;
    comp.release.value = 0.1;
    const analyser = ctx.createAnalyser();
    analyser.fftSize = 2048;
    analyser.smoothingTimeConstant = 0.6;
    master.connect(comp).connect(analyser).connect(ctx.destination);
    audioCtxRef.current = ctx;
    masterGainRef.current = master;
    analyserRef.current = analyser;
    setAudioReady(true);
  }, [masterVol]);

  useEffect(() => {
    if (masterGainRef.current && audioCtxRef.current) {
      masterGainRef.current.gain.setTargetAtTime(masterVol, audioCtxRef.current.currentTime, 0.01);
    }
  }, [masterVol]);

  // ---- Trigger ----
  const trigger = useCallback((drumName, vel = 1, when = null) => {
    const ctx = audioCtxRef.current;
    if (!ctx) return;
    if (ctx.state === "suspended") ctx.resume();
    const t = when ?? ctx.currentTime;
    const drum = DRUMS[drumName];
    const params = drums[drumName];
    if (!drum || !params) return;
    const drumGain = ctx.createGain();
    drumGain.gain.value = params.volume;
    drumGain.connect(masterGainRef.current);
    drum.synth(ctx, t, params, vel, drumGain);
    if (drumName === selectedDrum) {
      setFlashActive(true);
      if (flashTimerRef.current) clearTimeout(flashTimerRef.current);
      flashTimerRef.current = setTimeout(() => setFlashActive(false), 110);
    }
  }, [drums, selectedDrum]);

  const handleTriggerPress = () => {
    if (!audioCtxRef.current) initAudio();
    setTimeout(() => trigger(selectedDrum, 1), 0);
  };

  // ---- Flash ----
  const [flashActive, setFlashActive] = useState(false);
  const flashTimerRef = useRef(null);

  // ---- Sequencer engine with swing + humanize ----
  useEffect(() => {
    if (!playing) {
      setCurrentStep(-1);
      return;
    }
    const stepDur = (60 / bpm) / 4 * 1000;
    stepIdxRef.current = 0;
    const tick = () => {
      const idx = stepIdxRef.current;
      // Swing: delay off-beat 16ths (odd indices)
      let swingMs = (swing > 0 && idx % 2 === 1) ? stepDur * (swing / 100) : 0;
      DRUM_NAMES.forEach(name => {
        if (tracks[name][idx]) {
          // Humanize: random timing + velocity variation
          const humanMs = humanize > 0 ? (Math.random() - 0.5) * stepDur * (humanize / 60) : 0;
          const offset = Math.max(0, swingMs + humanMs);
          const vel = humanize > 0 ? 0.82 + Math.random() * 0.18 : 1;
          if (offset > 0.5) {
            setTimeout(() => trigger(name, vel), offset);
          } else {
            trigger(name, vel);
          }
        }
      });
      setCurrentStep(idx);
      stepIdxRef.current = (idx + 1) % 16;
    };
    tick();
    const id = setInterval(tick, stepDur);
    return () => clearInterval(id);
  }, [playing, bpm, tracks, trigger, swing, humanize]);

  const togglePlay = () => {
    if (!audioCtxRef.current) initAudio();
    setPlaying(p => !p);
  };

  const toggleStep = (drumName, i) => {
    setTracks(t => ({
      ...t,
      [drumName]: t[drumName].map((v, idx) => idx === i ? !v : v)
    }));
  };

  const clearTrack = (drumName) => {
    setTracks(t => ({ ...t, [drumName]: Array(16).fill(false) }));
  };

  const clearAllTracks = () => {
    const t = {};
    DRUM_NAMES.forEach(n => t[n] = Array(16).fill(false));
    setTracks(t);
  };

  const randomizeTrack = (drumName) => {
    const densityByDrum = { KICK: 0.25, SNARE: 0.18, "HAT-C": 0.55, "HAT-O": 0.12, CLAP: 0.15, TOM: 0.1, PERC: 0.25 };
    const d = densityByDrum[drumName] ?? 0.25;
    setTracks(t => ({
      ...t,
      [drumName]: Array.from({ length: 16 }, () => Math.random() < d)
    }));
  };

  // ---- Load kit ----
  const loadKit = (kitName) => {
    const kit = KITS[kitName];
    if (!kit) return;
    const newDrums = {};
    DRUM_NAMES.forEach(n => newDrums[n] = { ...kit[n] });
    setDrums(newDrums);
    const newTracks = {};
    DRUM_NAMES.forEach(n => newTracks[n] = [...kit.pattern[n]]);
    setTracks(newTracks);
    setBpm(kit.bpm);
  };

  // ---- Waveform display ----
  const canvasRef = useRef(null);
  useEffect(() => {
    if (!audioReady) return;
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx2d = canvas.getContext("2d");
    const analyser = analyserRef.current;
    const buf = new Uint8Array(analyser.fftSize);
    let raf;
    const dpr = window.devicePixelRatio || 1;
    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx2d.setTransform(1, 0, 0, 1, 0, 0);
      ctx2d.scale(dpr, dpr);
    };
    resize();
    const draw = () => {
      const rect = canvas.getBoundingClientRect();
      const W = rect.width, H = rect.height;
      analyser.getByteTimeDomainData(buf);
      ctx2d.clearRect(0, 0, W, H);
      ctx2d.strokeStyle = "rgba(255,255,255,0.03)";
      ctx2d.lineWidth = 1;
      for (let x = 0; x < W; x += W / 16) {
        ctx2d.beginPath(); ctx2d.moveTo(x, 0); ctx2d.lineTo(x, H); ctx2d.stroke();
      }
      ctx2d.strokeStyle = "rgba(255,107,26,0.13)";
      ctx2d.beginPath(); ctx2d.moveTo(0, H / 2); ctx2d.lineTo(W, H / 2); ctx2d.stroke();
      const accent = DRUMS[selectedDrum].color;
      ctx2d.strokeStyle = accent;
      ctx2d.lineWidth = 1.4;
      ctx2d.shadowBlur = 6;
      ctx2d.shadowColor = accent;
      ctx2d.beginPath();
      const slice = W / buf.length;
      for (let i = 0; i < buf.length; i++) {
        const v = (buf[i] - 128) / 128;
        const y = H / 2 + v * (H / 2) * 0.95;
        if (i === 0) ctx2d.moveTo(i * slice, y);
        else ctx2d.lineTo(i * slice, y);
      }
      ctx2d.stroke();
      ctx2d.shadowBlur = 0;
      raf = requestAnimationFrame(draw);
    };
    draw();
    window.addEventListener("resize", resize);
    return () => {
      cancelAnimationFrame(raf);
      window.removeEventListener("resize", resize);
    };
  }, [audioReady, selectedDrum]);

  // ---- Level meter ----
  const meterRef = useRef(null);
  useEffect(() => {
    if (!audioReady) return;
    const analyser = analyserRef.current;
    const buf = new Uint8Array(analyser.fftSize);
    let raf;
    const tick = () => {
      analyser.getByteTimeDomainData(buf);
      let peak = 0;
      for (let i = 0; i < buf.length; i++) {
        const v = Math.abs(buf[i] - 128) / 128;
        if (v > peak) peak = v;
      }
      if (meterRef.current) meterRef.current.style.width = `${Math.min(100, peak * 130)}%`;
      raf = requestAnimationFrame(tick);
    };
    tick();
    return () => cancelAnimationFrame(raf);
  }, [audioReady]);

  // ---- AI Sound Designer ----
  const [aiPrompt, setAiPrompt] = useState("");
  const [aiMode, setAiMode] = useState("drum"); // "drum" | "kit"
  const [aiThinking, setAiThinking] = useState(false);
  const [aiError, setAiError] = useState("");

  const askAI = async () => {
    if (!aiPrompt.trim() || aiThinking) return;
    setAiThinking(true);
    setAiError("");
    try {
      let sys, userMsg;
      if (aiMode === "drum") {
        const def = DRUMS[selectedDrum];
        const knobSpec = def.knobs.map(([k, _, mn, mx]) => `  - ${k}: ${mn}-${mx}`).join("\n");
        sys = `You design drum synth sounds. The user wants a ${selectedDrum} sound. Output ONLY a JSON object with these numeric keys (clamped to ranges):
${knobSpec}
No markdown, no prose. Match the description's vibe.`;
        userMsg = aiPrompt;
      } else {
        sys = `You design full electronic drum kits. Output ONLY a JSON object with this exact shape:
{
  "KICK": { "pitchStart": 60-400, "pitchEnd": 20-100, "pitchDecay": 5-250, "pitchCurve": 1-10, "ampDecay": 50-1500, "click": 0-1, "clickTone": 1500-10000, "sub": 0-1, "drive": 0-1, "volume": 0-1 },
  "SNARE": { "tone1": 100-400, "tone2": 200-600, "toneAmount": 0-1, "toneDecay": 20-500, "noiseAmount": 0-1, "noiseTone": 500-8000, "noiseDecay": 30-600, "drive": 0-1, "volume": 0-1 },
  "HAT-C": { "tone": 3000-12000, "decay": 10-200, "q": 0.5-8, "volume": 0-1 },
  "HAT-O": { "tone": 3000-12000, "decay": 100-800, "q": 0.5-8, "volume": 0-1 },
  "CLAP": { "tone": 500-4000, "q": 0.5-8, "decay": 50-600, "spread": 2-30, "drive": 0-1, "volume": 0-1 },
  "TOM": { "pitch": 60-400, "pitchEnd": 30-200, "pitchDecay": 20-400, "ampDecay": 100-1500, "click": 0-1, "drive": 0-1, "volume": 0-1 },
  "PERC": { "pitch1": 200-1200, "pitch2": 200-1200, "tone": 500-6000, "decay": 30-600, "drive": 0-1, "volume": 0-1 },
  "bpm": 60-180
}
No markdown, no prose. Match the style.`;
        userMsg = aiPrompt;
      }

      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1200,
          system: sys,
          messages: [{ role: "user", content: userMsg }],
        }),
      });
      const data = await res.json();
      const text = (data.content || []).filter(c => c.type === "text").map(c => c.text).join("");
      const cleaned = text.replace(/```json|```/g, "").trim();
      const parsed = JSON.parse(cleaned);

      if (aiMode === "drum") {
        // Apply to selected drum
        const def = DRUMS[selectedDrum];
        const next = { ...drums[selectedDrum] };
        def.knobs.forEach(([key, _, mn, mx]) => {
          if (typeof parsed[key] === "number") {
            next[key] = Math.max(mn, Math.min(mx, parsed[key]));
          }
        });
        setDrums(d => ({ ...d, [selectedDrum]: next }));
      } else {
        // Apply whole kit
        const newDrums = { ...drums };
        DRUM_NAMES.forEach(name => {
          if (parsed[name] && typeof parsed[name] === "object") {
            const def = DRUMS[name];
            const next = { ...drums[name] };
            def.knobs.forEach(([key, _, mn, mx]) => {
              if (typeof parsed[name][key] === "number") {
                next[key] = Math.max(mn, Math.min(mx, parsed[name][key]));
              }
            });
            newDrums[name] = next;
          }
        });
        setDrums(newDrums);
        if (typeof parsed.bpm === "number") {
          setBpm(Math.max(40, Math.min(220, parsed.bpm)));
        }
      }
      setAiPrompt("");
    } catch (e) {
      setAiError("AI couldn't parse — try again");
    } finally {
      setAiThinking(false);
    }
  };

  // ---- User kits (persistent) ----
  const [userKits, setUserKits] = useState({});
  const [savingName, setSavingName] = useState("");
  const [showSaveInput, setShowSaveInput] = useState(false);

  useEffect(() => {
    (async () => {
      try {
        const res = await window.storage.get("drumseek:kits");
        if (res?.value) setUserKits(JSON.parse(res.value));
      } catch (e) { /* none */ }
    })();
  }, []);

  const saveKit = async () => {
    const name = savingName.trim().toUpperCase().slice(0, 18);
    if (!name) return;
    const kit = { ...drums, pattern: { ...tracks }, bpm };
    const next = { ...userKits, [name]: kit };
    setUserKits(next);
    try { await window.storage.set("drumseek:kits", JSON.stringify(next)); } catch (e) {}
    setSavingName("");
    setShowSaveInput(false);
  };

  const deleteUserKit = async (name) => {
    const next = { ...userKits };
    delete next[name];
    setUserKits(next);
    try { await window.storage.set("drumseek:kits", JSON.stringify(next)); } catch (e) {}
  };

  const loadUserKit = (kitName) => {
    const kit = userKits[kitName];
    if (!kit) return;
    const newDrums = {};
    DRUM_NAMES.forEach(n => newDrums[n] = { ...kit[n] });
    setDrums(newDrums);
    if (kit.pattern) {
      const newTracks = {};
      DRUM_NAMES.forEach(n => newTracks[n] = [...(kit.pattern[n] || Array(16).fill(false))]);
      setTracks(newTracks);
    }
    if (kit.bpm) setBpm(kit.bpm);
  };

  // ---- Keyboard ----
  useEffect(() => {
    const onKey = (e) => {
      if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
      if (e.code === "Space") { e.preventDefault(); handleTriggerPress(); }
      if (e.code === "Enter") { e.preventDefault(); togglePlay(); }
      // Number keys 1-7 to select drums
      const num = parseInt(e.key);
      if (num >= 1 && num <= DRUM_NAMES.length) {
        setSelectedDrum(DRUM_NAMES[num - 1]);
      }
    };
    window.addEventListener("keydown", onKey);
    return () => window.removeEventListener("keydown", onKey);
  }, [trigger]);

  const sd = DRUMS[selectedDrum];

  return (
    <div className="w-full min-h-screen bg-neutral-950 text-neutral-200 font-mono-tight overflow-x-auto">
      <FontLoader />

      <div className="fixed inset-0 pointer-events-none">
        <div className="absolute inset-0 opacity-40" style={{
          background: "radial-gradient(ellipse at top, rgba(255,107,26,0.06), transparent 60%), radial-gradient(ellipse at bottom, rgba(34,211,238,0.04), transparent 60%)"
        }} />
        <div className="absolute inset-0" style={{
          backgroundImage: "radial-gradient(rgba(255,255,255,0.015) 1px, transparent 1px)",
          backgroundSize: "3px 3px"
        }} />
      </div>

      <div className="relative mx-auto p-4 lg:p-6" style={{ maxWidth: "1500px" }}>

        {/* HEADER */}
        <header className="flex items-center justify-between mb-4 pb-3 border-b border-neutral-800">
          <div className="flex items-center gap-3">
            <div className="w-8 h-8 rounded-sm bg-orange-600 relative overflow-hidden">
              <div className="absolute inset-0.5 rounded-sm bg-neutral-950 flex items-center justify-center">
                <div className="w-2 h-2 rounded-full" style={{ background: "#ff6b1a", color: "#ff6b1a", animation: "ledpulse 2s ease-in-out infinite" }} />
              </div>
            </div>
            <div>
              <h1 className="font-display text-3xl leading-none text-neutral-100">
                DRUM<span className="text-orange-500">SEEK</span>
              </h1>
              <div style={{ fontSize: "9px", letterSpacing: "0.28em" }} className="text-neutral-600 mt-0.5 uppercase">
                Multi-drum synthesis lab · v3.0
              </div>
            </div>
          </div>

          <div className="flex items-center gap-3">
            <div className="hidden sm:flex items-center gap-2 px-3 py-1.5 bg-neutral-900 border border-neutral-800 rounded-sm">
              <Power size={12} className={audioReady ? "text-orange-500" : "text-neutral-600"} />
              <span style={{ fontSize: "10px", letterSpacing: "0.18em" }} className="text-neutral-400 uppercase">
                {audioReady ? "Engaged" : "Standby"}
              </span>
            </div>
            <div className="hidden md:flex items-center gap-2">
              <Volume2 size={12} className="text-neutral-500" />
              <div className="w-32 h-1.5 bg-neutral-900 border border-neutral-800 rounded-sm overflow-hidden">
                <div ref={meterRef} className="h-full bg-gradient-to-r from-orange-600 via-orange-400 to-red-500" style={{ width: "0%", transition: "width 75ms" }} />
              </div>
            </div>
          </div>
        </header>

        {/* DRUM TABS */}
        <div className="flex flex-wrap gap-1 mb-3 p-1 bg-neutral-900 border border-neutral-800 rounded-sm">
          {DRUM_NAMES.map((name, idx) => {
            const def = DRUMS[name];
            const sel = selectedDrum === name;
            return (
              <button
                key={name}
                onClick={() => setSelectedDrum(name)}
                onDoubleClick={() => trigger(name, 1)}
                className={`flex-1 min-w-[80px] px-3 py-2 rounded-sm border transition-all ${
                  sel ? "border-neutral-600 bg-neutral-800" : "border-transparent hover:bg-neutral-800/50"
                }`}
                style={sel ? { boxShadow: `inset 0 -2px 0 ${def.color}` } : {}}
              >
                <div className="flex items-center justify-center gap-2">
                  <div className="w-1.5 h-1.5 rounded-full" style={{
                    background: sel ? def.color : "#404040",
                    boxShadow: sel ? `0 0 8px ${def.color}` : "none"
                  }} />
                  <span style={{
                    fontSize: "11px",
                    letterSpacing: "0.18em",
                    color: sel ? def.color : "#737373"
                  }} className="font-semibold uppercase">{name}</span>
                </div>
                <div style={{ fontSize: "8px", letterSpacing: "0.2em" }} className="text-neutral-600 text-center mt-0.5">[{idx + 1}]</div>
              </button>
            );
          })}
        </div>

        {/* SYNTH PARAMS + TRIGGER */}
        <div className="grid grid-cols-12 gap-3 mb-3">
          <Panel
            title={`◢ ${selectedDrum} · SYNTHESIS`}
            className="col-span-12 lg:col-span-9"
            accent
            accentColor={sd.color}
          >
            <div className="flex flex-wrap gap-x-3 gap-y-3 justify-start">
              {sd.knobs.map(([key, label, min, max, unit, format]) => (
                <Knob
                  key={`${selectedDrum}-${key}`}
                  label={label}
                  value={drums[selectedDrum][key]}
                  min={min}
                  max={max}
                  unit={unit}
                  format={format}
                  accent={sd.color}
                  onChange={(v) => setDrumParam(selectedDrum, key, v)}
                />
              ))}
            </div>
          </Panel>

          <Panel title="◢ TRIGGER" className="col-span-12 lg:col-span-3">
            <button
              onMouseDown={handleTriggerPress}
              onTouchStart={(e) => { e.preventDefault(); handleTriggerPress(); }}
              className="w-full rounded-sm border-2 transition-all duration-75 active:scale-95 flex flex-col items-center justify-center gap-1"
              style={{
                height: "138px",
                background: flashActive ? sd.color : "#171717",
                borderColor: flashActive ? sd.color : "#404040",
                boxShadow: flashActive ? `0 0 30px ${sd.color}99` : "none"
              }}
            >
              <div className="font-display text-2xl" style={{ color: flashActive ? "#0a0a0a" : "#525252" }}>
                {selectedDrum}
              </div>
              <div style={{ fontSize: "9px", letterSpacing: "0.25em", color: flashActive ? "#0a0a0a" : "#404040" }} className="uppercase">
                Press · Space
              </div>
            </button>
          </Panel>
        </div>

        {/* OSCILLOSCOPE */}
        <Panel title="◢ OSCILLOSCOPE" className="mb-3">
          <div className="relative bg-neutral-950 border border-neutral-800 rounded-sm overflow-hidden" style={{ height: "90px" }}>
            <canvas ref={canvasRef} className="absolute inset-0 w-full h-full" />
            <div style={{ fontSize: "9px", letterSpacing: "0.18em" }} className="absolute top-1.5 left-2 text-neutral-700 uppercase pointer-events-none">
              CH·1 · OUT
            </div>
            <div style={{ fontSize: "9px", letterSpacing: "0.18em", color: sd.color }} className="absolute top-1.5 right-2 uppercase pointer-events-none tabular-nums opacity-60">
              {audioReady ? `● ${selectedDrum}` : "○ STANDBY"}
            </div>
          </div>
        </Panel>

        {/* SEQUENCER */}
        <Panel title="◢ STEP SEQUENCER · MULTI-TRACK 16TH" className="mb-3">
          <div className="space-y-1.5">
            {DRUM_NAMES.map(name => {
              const def = DRUMS[name];
              return (
                <div key={name} className="flex items-center gap-2">
                  {/* Drum label + controls */}
                  <div className="flex items-center gap-1 w-[140px] shrink-0">
                    <button
                      onClick={() => setSelectedDrum(name)}
                      className={`flex-1 px-2 py-1.5 rounded-sm border transition-all ${
                        selectedDrum === name
                          ? "border-neutral-600 bg-neutral-800"
                          : "border-neutral-800 bg-neutral-900 hover:border-neutral-700"
                      }`}
                      style={selectedDrum === name ? { boxShadow: `inset 2px 0 0 ${def.color}` } : {}}
                    >
                      <div className="flex items-center gap-2">
                        <div className="w-1.5 h-1.5 rounded-full shrink-0" style={{ background: def.color }} />
                        <span style={{ fontSize: "10px", letterSpacing: "0.15em", color: def.color }} className="font-semibold uppercase">
                          {name}
                        </span>
                      </div>
                    </button>
                    <button
                      onClick={() => randomizeTrack(name)}
                      title="Randomize this track"
                      className="p-1.5 text-neutral-600 hover:text-neutral-300 border border-neutral-800 hover:border-neutral-600 rounded-sm"
                    >
                      <Shuffle size={10} />
                    </button>
                    <button
                      onClick={() => clearTrack(name)}
                      title="Clear this track"
                      className="p-1.5 text-neutral-600 hover:text-red-500 border border-neutral-800 hover:border-neutral-600 rounded-sm"
                    >
                      <Trash2 size={10} />
                    </button>
                  </div>

                  {/* Steps */}
                  <div className="flex-1 grid gap-1" style={{ gridTemplateColumns: "repeat(16, minmax(0, 1fr))" }}>
                    {tracks[name].map((on, i) => {
                      const isCurrent = currentStep === i;
                      const isBeat = i % 4 === 0;
                      const lit = on;
                      return (
                        <button
                          key={i}
                          onClick={() => toggleStep(name, i)}
                          className="relative h-8 rounded-sm border transition-all duration-75"
                          style={{
                            background: lit
                              ? (isCurrent ? def.color : `${def.color}b3`)
                              : (isCurrent ? "#404040" : (isBeat ? "#1f1f1f" : "#0f0f0f")),
                            borderColor: lit
                              ? (isCurrent ? def.color : `${def.color}60`)
                              : (isCurrent ? "#525252" : (isBeat ? "#404040" : "#262626")),
                            boxShadow: lit && isCurrent ? `0 0 10px ${def.color}aa` : "none"
                          }}
                        >
                          {isBeat && (
                            <span style={{ fontSize: "8px" }} className="absolute top-0.5 left-1 text-neutral-500 tabular-nums pointer-events-none">
                              {Math.floor(i / 4) + 1}
                            </span>
                          )}
                        </button>
                      );
                    })}
                  </div>
                </div>
              );
            })}
          </div>

          {/* Transport + Groove */}
          <div className="mt-4 pt-3 border-t border-neutral-800 flex flex-wrap items-center gap-3">
            <div className="flex items-center gap-2">
              <button
                onClick={togglePlay}
                className="w-12 h-12 rounded-sm border-2 flex items-center justify-center transition-all"
                style={{
                  background: playing ? "#ff6b1a" : "#171717",
                  borderColor: playing ? "#ff8a3d" : "#404040",
                  color: playing ? "#0a0a0a" : "#d4d4d4"
                }}
              >
                {playing ? <Square size={16} fill="currentColor" /> : <Play size={16} fill="currentColor" />}
              </button>
              <button
                onClick={clearAllTracks}
                className="w-12 h-12 rounded-sm border-2 border-neutral-700 bg-neutral-900 text-neutral-500 hover:text-neutral-300 hover:border-neutral-500 flex items-center justify-center"
                title="Clear all patterns"
              >
                <Trash2 size={14} />
              </button>
            </div>

            {/* BPM */}
            <div className="flex flex-col items-center px-3 py-1 border border-neutral-800 bg-neutral-950 rounded-sm">
              <span style={{ fontSize: "8px", letterSpacing: "0.2em" }} className="text-neutral-500 uppercase">TEMPO</span>
              <input
                type="number"
                value={bpm}
                min={40}
                max={220}
                onChange={(e) => setBpm(Math.max(40, Math.min(220, +e.target.value || 120)))}
                className="w-14 bg-transparent text-orange-500 text-xl font-mono-tight font-bold text-center tabular-nums focus:outline-none"
              />
              <span style={{ fontSize: "8px", letterSpacing: "0.2em" }} className="text-neutral-600 uppercase">BPM</span>
            </div>

            {/* Groove knobs */}
            <div className="flex items-center gap-3 px-3 py-1.5 border border-neutral-800 bg-neutral-950 rounded-sm">
              <Knob
                label="SWING"
                value={swing}
                min={0}
                max={50}
                unit="%"
                format={(v) => `${Math.round(v)}`}
                accent="#22d3ee"
                onChange={setSwing}
                size={48}
              />
              <Knob
                label="HUMAN"
                value={humanize}
                min={0}
                max={15}
                unit="%"
                format={(v) => `${Math.round(v)}`}
                accent="#22d3ee"
                onChange={setHumanize}
                size={48}
              />
              <Knob
                label="MASTER"
                value={masterVol}
                min={0}
                max={1}
                format={(v) => `${Math.round(v * 100)}`}
                accent="#22d3ee"
                onChange={setMasterVol}
                size={48}
              />
            </div>

            <div className="ml-auto" style={{ fontSize: "9px", letterSpacing: "0.2em" }}>
              <span className="text-neutral-600 uppercase">Step </span>
              <span className="text-orange-500 tabular-nums">{currentStep >= 0 ? String(currentStep + 1).padStart(2, "0") : "--"}</span>
              <span className="text-neutral-700"> / 16</span>
            </div>
          </div>
        </Panel>

        {/* KITS + AI */}
        <div className="grid grid-cols-12 gap-3">
          {/* Kits */}
          <Panel title="◢ DRUM KITS" className="col-span-12 lg:col-span-7">
            <div className="grid grid-cols-2 sm:grid-cols-4 gap-1.5">
              {KIT_NAMES.map(name => (
                <button
                  key={name}
                  onClick={() => loadKit(name)}
                  className="px-2 py-2 bg-neutral-950 border border-neutral-800 hover:border-orange-600 hover:bg-neutral-900 rounded-sm uppercase text-neutral-300 hover:text-orange-400 font-medium transition-all text-left"
                  style={{ fontSize: "10px", letterSpacing: "0.13em" }}
                >
                  <span className="text-neutral-600 mr-1.5">▸</span>{name}
                </button>
              ))}
            </div>

            {Object.keys(userKits).length > 0 && (
              <div className="mt-3 pt-3 border-t border-neutral-800">
                <div style={{ fontSize: "9px", letterSpacing: "0.22em" }} className="text-neutral-500 uppercase mb-2">Your Kits</div>
                <div className="grid grid-cols-2 sm:grid-cols-4 gap-1.5">
                  {Object.keys(userKits).map(name => (
                    <div key={name} className="group flex items-center bg-neutral-950 border border-neutral-800 hover:border-cyan-700 rounded-sm overflow-hidden">
                      <button
                        onClick={() => loadUserKit(name)}
                        className="flex-1 px-2 py-2 uppercase text-neutral-300 hover:text-cyan-400 font-medium text-left transition-colors"
                        style={{ fontSize: "10px", letterSpacing: "0.13em" }}
                      >
                        <span className="text-neutral-600 mr-1.5">▸</span>{name}
                      </button>
                      <button
                        onClick={() => deleteUserKit(name)}
                        className="px-1.5 text-neutral-700 hover:text-red-500 opacity-0 transition-opacity"
                        style={{}}
                      >
                        <Trash2 size={11} />
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div className="mt-3 pt-3 border-t border-neutral-800">
              {showSaveInput ? (
                <div className="flex gap-1.5">
                  <input
                    type="text"
                    value={savingName}
                    onChange={(e) => setSavingName(e.target.value)}
                    onKeyDown={(e) => e.key === "Enter" && saveKit()}
                    placeholder="KIT NAME"
                    autoFocus
                    className="flex-1 px-3 py-2 bg-neutral-950 border border-neutral-700 rounded-sm uppercase text-neutral-200 placeholder-neutral-700 focus:outline-none focus:border-orange-600"
                    style={{ fontSize: "11px", letterSpacing: "0.15em" }}
                  />
                  <button onClick={saveKit} className="px-4 bg-orange-600 hover:bg-orange-500 text-neutral-950 uppercase font-bold rounded-sm" style={{ fontSize: "10px", letterSpacing: "0.18em" }}>
                    Save
                  </button>
                  <button onClick={() => { setShowSaveInput(false); setSavingName(""); }} className="px-3 border border-neutral-700 text-neutral-500 uppercase rounded-sm hover:text-neutral-300" style={{ fontSize: "10px" }}>
                    ×
                  </button>
                </div>
              ) : (
                <button
                  onClick={() => setShowSaveInput(true)}
                  className="w-full flex items-center justify-center gap-2 px-3 py-2 border border-dashed border-neutral-700 hover:border-orange-600 text-neutral-500 hover:text-orange-400 rounded-sm uppercase transition-colors"
                  style={{ fontSize: "10px", letterSpacing: "0.2em" }}
                >
                  <Save size={11} /> Save Current Kit + Pattern
                </button>
              )}
            </div>
          </Panel>

          {/* AI */}
          <Panel title="◢ AI SOUND DESIGNER" className="col-span-12 lg:col-span-5" accent accentColor="#ff6b1a">
            <div className="space-y-2">
              {/* Mode toggle */}
              <div className="flex gap-1 p-0.5 bg-neutral-950 border border-neutral-800 rounded-sm">
                <button
                  onClick={() => setAiMode("drum")}
                  className={`flex-1 py-1.5 rounded-sm uppercase font-semibold transition-all ${
                    aiMode === "drum" ? "bg-neutral-800 text-orange-400" : "text-neutral-500 hover:text-neutral-300"
                  }`}
                  style={{ fontSize: "10px", letterSpacing: "0.15em" }}
                >
                  This Drum ({selectedDrum})
                </button>
                <button
                  onClick={() => setAiMode("kit")}
                  className={`flex-1 py-1.5 rounded-sm uppercase font-semibold transition-all ${
                    aiMode === "kit" ? "bg-neutral-800 text-orange-400" : "text-neutral-500 hover:text-neutral-300"
                  }`}
                  style={{ fontSize: "10px", letterSpacing: "0.15em" }}
                >
                  Whole Kit
                </button>
              </div>
              <textarea
                value={aiPrompt}
                onChange={(e) => setAiPrompt(e.target.value)}
                onKeyDown={(e) => {
                  if (e.key === "Enter" && (e.metaKey || e.ctrlKey)) askAI();
                }}
                placeholder={aiMode === "drum" ? `e.g. punchy ${selectedDrum.toLowerCase()} for techno...` : "e.g. dusty boom-bap kit with vinyl crackle..."}
                rows={2}
                className="w-full px-3 py-2 bg-neutral-950 border border-neutral-800 rounded-sm text-neutral-200 placeholder-neutral-700 focus:outline-none focus:border-orange-600 resize-none font-mono-tight"
                style={{ fontSize: "12px" }}
              />
              {aiError && (
                <div style={{ fontSize: "10px" }} className="text-red-500 tracking-wide">{aiError}</div>
              )}
              <div className="flex flex-wrap gap-1.5">
                {(aiMode === "drum"
                  ? ["punchy", "deep & boomy", "crispy", "lo-fi", "aggressive"]
                  : ["dusty boom-bap", "deep tech", "minimal", "trap", "drum & bass"]
                ).map(s => (
                  <button
                    key={s}
                    onClick={() => setAiPrompt(s)}
                    className="px-2 py-1 uppercase border border-neutral-800 text-neutral-500 hover:text-cyan-400 hover:border-cyan-700 rounded-sm"
                    style={{ fontSize: "9px", letterSpacing: "0.15em" }}
                  >
                    {s}
                  </button>
                ))}
              </div>
              <button
                onClick={askAI}
                disabled={aiThinking || !aiPrompt.trim()}
                className="w-full flex items-center justify-center gap-2 px-3 py-2.5 bg-orange-600 hover:bg-orange-500 disabled:bg-neutral-800 disabled:text-neutral-600 text-neutral-950 uppercase font-bold rounded-sm transition-all"
                style={{ fontSize: "11px", letterSpacing: "0.2em" }}
              >
                <Sparkles size={12} />
                {aiThinking ? "Designing..." : aiMode === "drum" ? `Generate ${selectedDrum}` : "Generate Kit"}
              </button>
            </div>
          </Panel>
        </div>

        {/* FOOTER */}
        <footer className="mt-6 pt-3 border-t border-neutral-900 flex flex-wrap justify-between items-center gap-2 text-neutral-700 uppercase" style={{ fontSize: "9px", letterSpacing: "0.22em" }}>
          <div>Drag knobs · Shift=fine · Dbl-click=reset</div>
          <div>1–7: select drum · SPACE: trigger · ENTER: play · Dbl-click tab: preview</div>
        </footer>
      </div>
    </div>
  );
}