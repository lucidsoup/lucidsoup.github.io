// ============================================================================
// KNOB COMPONENT
// ============================================================================
function Knob({ value, min, max, onChange, label, format, unit = "", size = 56, accent = "#ff6b1a", defaultValue }) {
  const dragging = useRef(false);
  const startY = useRef(0);
  const startVal = useRef(0);
  const range = max - min;
  const norm = (value - min) / range;
  const angle = norm * 270 - 135;
  const arcLength = 240;
  const dashOn = norm * arcLength;

  useEffect(() => {
    const onMove = (e) => {
      if (!dragging.current) return;
      const cy = e.touches ? e.touches[0].clientY : e.clientY;
      const dy = startY.current - cy;
      const sens = e.shiftKey ? 600 : 180;
      const nv = startVal.current + (dy / sens) * range;
      onChange(Math.max(min, Math.min(max, nv)));
    };
    const onUp = () => {
      if (dragging.current) {
        dragging.current = false;
        document.body.style.cursor = "";
      }
    };
    window.addEventListener("mousemove", onMove);
    window.addEventListener("mouseup", onUp);
    window.addEventListener("touchmove", onMove, { passive: false });
    window.addEventListener("touchend", onUp);
    return () => {
      window.removeEventListener("mousemove", onMove);
      window.removeEventListener("mouseup", onUp);
      window.removeEventListener("touchmove", onMove);
      window.removeEventListener("touchend", onUp);
    };
  }, [min, max, range, onChange]);

  const onDown = (e) => {
    e.preventDefault();
    dragging.current = true;
    startY.current = e.touches ? e.touches[0].clientY : e.clientY;
    startVal.current = value;
    document.body.style.cursor = "ns-resize";
  };
  const onDouble = () => onChange(defaultValue ?? min + range * 0.5);

  const gradId = `g-${label}-${Math.round(min)}`;
  return (
    <div className="flex flex-col items-center gap-1 select-none">
      <div
        onMouseDown={onDown}
        onTouchStart={onDown}
        onDoubleClick={onDouble}
        className="relative cursor-ns-resize touch-none"
        style={{ width: size, height: size }}
        title="Drag • Shift=fine • Dbl-click reset"
      >
        <svg width={size} height={size} viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="44" fill="none" stroke="#1f1f1f" strokeWidth="3" />
          <circle
            cx="50" cy="50" r="44" fill="none" stroke={accent} strokeWidth="3"
            strokeLinecap="round"
            strokeDasharray={`${dashOn} ${arcLength}`}
            transform="rotate(135 50 50)"
            style={{ filter: `drop-shadow(0 0 3px ${accent})` }}
          />
          <defs>
            <radialGradient id={gradId} cx="50%" cy="35%">
              <stop offset="0%" stopColor="#2e2e2e" />
              <stop offset="60%" stopColor="#161616" />
              <stop offset="100%" stopColor="#080808" />
            </radialGradient>
          </defs>
          <circle cx="50" cy="50" r="34" fill={`url(#${gradId})`} stroke="#3a3a3a" strokeWidth="0.5" />
          <g transform={`rotate(${angle} 50 50)`}>
            <line x1="50" y1="20" x2="50" y2="34" stroke={accent} strokeWidth="3" strokeLinecap="round"
              style={{ filter: `drop-shadow(0 0 2px ${accent})` }} />
          </g>
          <circle cx="50" cy="50" r="3" fill="#0a0a0a" stroke="#404040" strokeWidth="0.5" />
        </svg>
      </div>
      <div style={{ fontSize: "9px", letterSpacing: "0.18em" }} className="text-neutral-500 uppercase font-mono-tight">{label}</div>
      <div style={{ fontSize: "10px", color: accent }} className="tabular-nums font-mono-tight font-medium leading-none">
        {format ? format(value) : `${value < 10 ? value.toFixed(1) : Math.round(value)}${unit}`}
      </div>
    </div>
  );
}

